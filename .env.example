# URL de l'API Backend
VITE_API_URL=http://localhost:3000

# URL de l'API Admin (si différente)
VITE_ADMIN_API_URL=http://localhost:3000/admin

# URL du Front Office
VITE_FRONT_OFFICE_URL=http://localhost:8085

# Activer/Désactiver les données mockées (true/false)
VITE_USE_MOCK=false

# Google OAuth2 (Client ID pour le frontend)
VITE_GOOGLE_CLIENT_ID=your-google-client-id
